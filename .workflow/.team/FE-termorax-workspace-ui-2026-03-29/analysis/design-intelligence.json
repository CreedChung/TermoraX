{
  "_source": "llm-general-knowledge",
  "project": "TermoraX",
  "industry": "DevTools/SSH-Client",
  "detected_stack": {
    "framework": "react-19",
    "styling": "tailwindcss-v4",
    "ui_library": "shadcn-ui",
    "build_tool": "vite",
    "desktop": "tauri-2"
  },
  "analysis_summary": {
    "current_issues": [
      "47+ hardcoded rgba() transparency values in CSS",
      "Inconsistent border styling (mix of rgba values)",
      "Missing semantic design token hierarchy",
      "No systematic shadow/elevation system",
      "Panel spacing lacks consistency"
    ],
    "design_goals": [
      "Unified design token system",
      "Modernized dark theme with better contrast",
      "WCAG AA accessibility compliance",
      "Consistent 8px grid spacing",
      "Professional developer tool aesthetic"
    ]
  },
  "design_system": {
    "color_strategy": {
      "approach": "semantic-token-based",
      "base_palette": {
        "background": {
          "primary": "#101316",
          "secondary": "#12171d",
          "tertiary": "#1b232b"
        },
        "surface": {
          "default": "rgba(18, 23, 29, 0.95)",
          "elevated": "rgba(33, 42, 52, 0.98)",
          "overlay": "rgba(0, 0, 0, 0.80)"
        },
        "accent": {
          "primary": "#f2a05c",
          "secondary": "#6fcf97",
          "danger": "#ff8d7d",
          "info": "#7dd3fc"
        },
        "text": {
          "primary": "#f5f1e8",
          "secondary": "#b5b0a5",
          "muted": "#8a8479",
          "inverse": "#101316"
        }
      },
      "token_structure": {
        "semantic_naming": "--<category>-<variant>-<state>",
        "categories": ["bg", "surface", "text", "border", "accent", "state"],
        "variants": ["default", "primary", "secondary", "muted", "elevated"],
        "states": ["default", "hover", "active", "disabled", "focus"]
      }
    },
    "typography": {
      "font_family": "'Segoe UI Variable', 'Noto Sans', system-ui, sans-serif",
      "mono_family": "'JetBrains Mono', 'Cascadia Code', Consolas, monospace",
      "scale": {
        "xs": { "size": "11px", "lineHeight": "16px", "letterSpacing": "0.01em" },
        "sm": { "size": "12px", "lineHeight": "18px", "letterSpacing": "0" },
        "base": { "size": "13px", "lineHeight": "20px", "letterSpacing": "0" },
        "lg": { "size": "14px", "lineHeight": "22px", "letterSpacing": "-0.01em" },
        "xl": { "size": "16px", "lineHeight": "24px", "letterSpacing": "-0.01em" }
      }
    },
    "spacing": {
      "grid": "8px",
      "scale": {
        "0": "0px",
        "1": "4px",
        "2": "8px",
        "3": "12px",
        "4": "16px",
        "5": "20px",
        "6": "24px",
        "8": "32px",
        "10": "40px",
        "12": "48px"
      },
      "component_gaps": {
        "xs": "4px",
        "sm": "6px",
        "md": "8px",
        "lg": "12px",
        "xl": "16px"
      }
    },
    "borders": {
      "widths": {
        "thin": "1px",
        "medium": "2px",
        "thick": "3px"
      },
      "styles": {
        "default": "solid",
        "subtle": "1px solid var(--border-default)",
        "focus": "2px solid var(--accent-primary)"
      },
      "radius": {
        "sm": "6px",
        "md": "8px",
        "lg": "12px",
        "xl": "16px",
        "full": "9999px"
      }
    },
    "shadows": {
      "elevation": {
        "1": "0 1px 2px rgba(0, 0, 0, 0.20)",
        "2": "0 4px 8px rgba(0, 0, 0, 0.24)",
        "3": "0 8px 16px rgba(0, 0, 0, 0.28)",
        "4": "0 12px 24px rgba(0, 0, 0, 0.32)",
        "5": "0 20px 40px rgba(0, 0, 0, 0.36)"
      },
      "glow": {
        "accent": "0 0 20px rgba(242, 160, 92, 0.15)",
        "focus": "0 0 0 3px rgba(242, 160, 92, 0.20)"
      }
    }
  },
  "ux_guidelines": {
    "accessibility": {
      "contrast_ratio": "WCAG AA: 4.5:1 for normal text, 3:1 for large text",
      "focus_indicators": "Visible focus rings with accent color",
      "keyboard_navigation": "Full keyboard support with visible shortcuts",
      "screen_reader": "Proper ARIA labels and semantic HTML"
    },
    "interaction": {
      "hover_states": "Subtle background color changes, never rely on color alone",
      "active_states": "Slightly darker backgrounds or accent overlays",
      "disabled_states": "Reduced opacity (0.5) with cursor: not-allowed",
      "loading_states": "Skeleton screens or spinners with reduced opacity"
    },
    "layout": {
      "terminal_aesthetic": "Dark backgrounds with high contrast text",
      "panel_organization": "Clear visual hierarchy with consistent spacing",
      "resizable_panels": "Visual splitters with hover feedback",
      "compact_density": "Developer-focused, information-dense UI"
    }
  },
  "stack_guidelines": {
    "tailwind_v4": {
      "theme_config": "Use @theme directive for custom properties",
