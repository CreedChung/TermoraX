    ],
    "color_changes": [
      "Increase surface opacity to 0.95-0.98 for better contrast",
      "Border opacity: 0.08 -> 0.12 for better visibility",
      "Add --surface-hover variants for interactive elements",
      "Maintain accent #f2a05c for brand consistency"
    ],
    "anti_patterns_to_fix": [
