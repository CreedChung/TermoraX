      "dark_mode": "Class-based with .dark selector"
    },
    "shadcn_ui": {
      "component_variants": "Use cva for component variants",
      "theme_integration": "Extend shadcn theme with custom tokens",
      "css_variables": "Align with shadcn's --ui-* variable naming"
    },
    "react_19": {
      "component_structure": "Functional components with hooks",
      "state_management": "Local state for UI, context for shared state",
