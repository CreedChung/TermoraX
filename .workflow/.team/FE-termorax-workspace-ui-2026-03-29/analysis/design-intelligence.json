  "existing_patterns": {
    "current_color_tokens": [
      "--surface: rgba(18, 23, 29, 0.92)",
      "--surface-alt: rgba(27, 35, 43, 0.92)",
      "--border: rgba(243, 229, 207, 0.08)",
      "--accent: #f2a05c"
    ],
    "border_usage": "rgba(243, 229, 207, 0.08) with subtle 8% opacity",
    "opacity_patterns": "Multiple 0.92, 0.70-0.95 range for surfaces"
  },
  "recommendations": {
    "style_patterns": [
      "Replace all hardcoded rgba() with semantic CSS variables",
      "Use --surface-* tokens for background layers",
      "Standardize border to --border-default (12% opacity)",
      "Apply consistent 8px spacing grid",
