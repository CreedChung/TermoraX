{
  "$schema": "https://tokens.studio/schema.json",
  "name": "TermoraX Design Tokens",
  "version": "1.0.0",
  "description": "Design token system for TermoraX SSH/SFTP workspace UI",
  "tokens": {
    "color": {
      "background": {
        "primary": {
          "$type": "color",
          "$value": "#101316",
          "$description": "Main application background"
        },
        "secondary": {
          "$type": "color",
          "$value": "#12171d",
          "$description": "Secondary background layer"
        },
        "tertiary": {
          "$type": "color",
          "$value": "#1b232b",
          "$description": "Tertiary background for nested panels"
        }
      },
      "surface": {
        "default": {
          "$type": "color",
          "$value": "rgba(18, 23, 29, 0.95)",
          "$description": "Default surface for cards and panels"
        },
        "hover": {
          "$type": "color",
          "$value": "rgba(40, 49, 59, 0.85)",
          "$description": "Surface hover state"
        },
        "active": {
          "$type": "color",
          "$value": "rgba(242, 160, 92, 0.12)",
          "$description": "Surface active/selected state"
        },
        "elevated": {
          "$type": "color",
          "$value": "rgba(33, 42, 52, 0.98)",
          "$description": "Elevated surface for dialogs and popovers"
        },
        "overlay": {
          "$type": "color",
          "$value": "rgba(0, 0, 0, 0.80)",
          "$description": "Overlay for modals and backdrops"
        },
        "disabled": {
          "$type": "color",
          "$value": "rgba(16, 20, 24, 0.56)",
          "$description": "Disabled state background"
        }
      },
      "text": {
        "primary": {
          "$type": "color",
          "$value": "#f5f1e8",
          "$description": "Primary text color, high contrast"
        },
        "secondary": {
          "$type": "color",
          "$value": "#b5b0a5",
          "$description": "Secondary text color"
        },
        "muted": {
          "$type": "color",
          "$value": "#8a8479",
          "$description": "Muted text for hints and metadata"
        },
        "inverse": {
          "$type": "color",
          "$value": "#101316",
          "$description": "Text on light backgrounds"
        },
        "disabled": {
          "$type": "color",
          "$value": "rgba(181, 176, 165, 0.5)",
          "$description": "Disabled text"
        }
      },
      "border": {
        "default": {
          "$type": "color",
          "$value": "rgba(243, 229, 207, 0.12)",
          "$description": "Default border color"
        },
        "hover": {
          "$type": "color",
          "$value": "rgba(243, 229, 207, 0.20)",
          "$description": "Border hover state"
        },
        "focus": {
          "$type": "color",
          "$value": "rgba(242, 160, 92, 0.44)",
          "$description": "Border focus state with accent"
        },
        "active": {
          "$type": "color",
          "$value": "rgba(242, 160, 92, 0.60)",
          "$description": "Border active/selected state"
        },
        "subtle": {
          "$type": "color",
          "$value": "rgba(243, 229, 207, 0.06)",
          "$description": "Very subtle border"
        }
      },
      "accent": {
        "primary": {
          "$type": "color",
          "$value": "#f2a05c",
          "$description": "Primary accent (warm orange)"
        },
        "primary-hover": {
          "$type": "color",
          "$value": "#ffb078",
          "$description": "Primary accent hover"
        },
        "primary-active": {
          "$type": "color",
          "$value": "#e08c48",
          "$description": "Primary accent active"
        },
        "primary-subtle": {
          "$type": "color",
          "$value": "rgba(242, 160, 92, 0.18)",
          "$description": "Subtle primary accent background"
        },
        "secondary": {
          "$type": "color",
          "$value": "#6fcf97",
          "$description": "Secondary accent (success green)"
        },
        "danger": {
          "$type": "color",
          "$value": "#ff8d7d",
          "$description": "Danger/error accent"
        },
        "danger-subtle": {
          "$type": "color",
          "$value": "rgba(255, 141, 125, 0.16)",
          "$description": "Subtle danger background"
        },
        "warning": {
          "$type": "color",
          "$value": "#f59e0b",
          "$description": "Warning accent"
        },
        "info": {
          "$type": "color",
          "$value": "#7dd3fc",
          "$description": "Info accent (blue)"
        }
      },
      "state": {
        "success": {
          "$type": "color",
          "$value": "#6fcf97",
          "$description": "Success state"
        },
        "error": {
          "$type": "color",
          "$value": "#ff8d7d",
          "$description": "Error state"
        },
        "warning": {
          "$type": "color",
          "$value": "#f59e0b",
          "$description": "Warning state"
        },
        "info": {
          "$type": "color",
          "$value": "#7dd3fc",
          "$description": "Info state"
        }
      },
      "terminal": {
        "bg-default": {
          "$type": "color",
          "$value": "#0c1014",
          "$description": "Terminal background"
        },
        "bg-sand": {
          "$type": "color",
          "$value": "#efe7d9",
          "$description": "Terminal sand theme background"
        },
        "text-default": {
          "$type": "color",
          "$value": "#dce8d8",
          "$description": "Terminal text color"
        },
        "text-sand": {
          "$type": "color",
          "$value": "#2a2418",
          "$description": "Terminal sand theme text"
        }
      },
      "code": {
        "surface": {
          "$type": "color",
          "$value": "rgba(0, 0, 0, 0.20)",
          "$description": "Code block background"
        },
        "text": {
          "$type": "color",
          "$value": "#f4eee4",
          "$description": "Code text color"
        }
      }
    },
    "fontFamily": {
      "sans": {
        "$type": "fontFamily",
        "$value": ["Segoe UI Variable", "Noto Sans", "system-ui", "sans-serif"],
        "$description": "Primary sans-serif font stack"
      },
      "mono": {
        "$type": "fontFamily",
        "$value": ["JetBrains Mono", "Cascadia Code", "Consolas", "monospace"],
        "$description": "Monospace font for code"
      }
    },
    "fontSize": {
      "xs": {
        "$type": "fontSize",
        "$value": "11px",
        "$description": "Extra small text (labels, badges)"
      },
      "sm": {
        "$type": "fontSize",
        "$value": "12px",
        "$description": "Small text (captions, metadata)"
      },
      "base": {
        "$type": "fontSize",
        "$value": "13px",
        "$description": "Base text size (body)"
      },
      "lg": {
        "$type": "fontSize",
        "$value": "14px",
        "$description": "Large text"
      },
      "xl": {
        "$type": "fontSize",
        "$value": "16px",
        "$description": "Extra large text (headings)"
      }
    },
    "lineHeight": {
      "xs": {
        "$type": "lineHeight",
        "$value": "16px"
      },
      "sm": {
        "$type": "lineHeight",
        "$value": "18px"
      },
      "base": {
        "$type": "lineHeight",
        "$value": "20px"
      },
      "lg": {
        "$type": "lineHeight",
        "$value": "22px"
      },
      "xl": {
        "$type": "lineHeight",
        "$value": "24px"
      }
    },
    "letterSpacing": {
      "tight": {
        "$type": "letterSpacing",
        "$value": "-0.01em"
      },
      "normal": {
        "$type": "letterSpacing",
        "$value": "0"
      },
      "wide": {
        "$type": "letterSpacing",
        "$value": "0.01em"
      }
    },
    "spacing": {
      "0": {
        "$type": "dimension",
        "$value": "0px"
      },
      "1": {
        "$type": "dimension",
        "$value": "4px"
      },
      "2": {
        "$type": "dimension",
        "$value": "8px"
      },
      "3": {
        "$type": "dimension",
        "$value": "12px"
      },
      "4": {
        "$type": "dimension",
        "$value": "16px"
      },
      "5": {
        "$type": "dimension",
        "$value": "20px"
      },
      "6": {
        "$type": "dimension",
        "$value": "24px"
      },
      "8": {
        "$type": "dimension",
        "$value": "32px"
      },
      "10": {
        "$type": "dimension",
        "$value": "40px"
      },
      "12": {
        "$type": "dimension",
        "$value": "48px"
      }
    },
    "borderRadius": {
      "sm": {
        "$type": "dimension",
        "$value": "6px"
      },
      "md": {
        "$type": "dimension",
        "$value": "8px"
      },
      "lg": {
        "$type": "dimension",
        "$value": "12px"
      },
      "xl": {
        "$type": "dimension",
        "$value": "16px"
      },
      "full": {
        "$type": "dimension",
        "$value": "9999px"
      }
    },
    "borderWidth": {
      "thin": {
        "$type": "dimension",
        "$value": "1px"
      },
      "medium": {
        "$type": "dimension",
        "$value": "2px"
      },
      "thick": {
        "$type": "dimension",
        "$value": "3px"
      }
    },
    "shadow": {
      "sm": {
        "$type": "shadow",
        "$value": {
          "x": "0",
          "y": "1px",
          "blur": "2px",
          "spread": "0",
          "color": "rgba(0, 0, 0, 0.20)"
        }
      },
      "md": {
        "$type": "shadow",
        "$value": {
          "x": "0",
          "y": "4px",
          "blur": "8px",
          "spread": "0",
          "color": "rgba(0, 0, 0, 0.24)"
        }
      },
      "lg": {
        "$type": "shadow",
        "$value": {
          "x": "0",
          "y": "8px",
          "blur": "16px",
          "spread": "0",
          "color": "rgba(0, 0, 0, 0.28)"
        }
      },
      "xl": {
        "$type": "shadow",
        "$value": {
          "x": "0",
          "y": "12px",
          "blur": "24px",
          "spread": "0",
          "color": "rgba(0, 0, 0, 0.32)"
        }
      },
      "2xl": {
        "$type": "shadow",
        "$value": {
          "x": "0",
          "y": "20px",
          "blur": "40px",
          "spread": "0",
          "color": "rgba(0, 0, 0, 0.36)"
        }
      },
      "glow-accent": {
        "$type": "shadow",
        "$value": {
          "x": "0",
          "y": "0",
          "blur": "20px",
          "spread": "0",
          "color": "rgba(242, 160, 92, 0.15)"
        }
      },
      "focus-ring": {
        "$type": "shadow",
        "$value": {
          "x": "0",
          "y": "0",
          "blur": "0",
          "spread": "3px",
          "color": "rgba(242, 160, 92, 0.20)"
        }
      }
    },
    "transition": {
      "fast": {
        "$type": "duration",
        "$value": "150ms"
      },
      "normal": {
        "$type": "duration",
        "$value": "200ms"
      },
      "slow": {
        "$type": "duration",
        "$value": "300ms"
      }
    },
    "zIndex": {
      "base": {
        "$type": "number",
        "$value": 0
      },
      "dropdown": {
        "$type": "number",
        "$value": 10
      },
      "sticky": {
        "$type": "number",
        "$value": 20
      },
      "popover": {
        "$type": "number",
        "$value": 30
      },
      "modal": {
        "$type": "number",
        "$value": 40
      },
      "tooltip": {
        "$type": "number",
        "$value": 50
      }
    },
    "opacity": {
      "0": {
        "$type": "number",
        "$value": 0
      },
      "disabled": {
        "$type": "number",
        "$value": 0.5
      },
      "subtle": {
        "$type": "number",
        "$value": 0.7
      },
      "muted": {
        "$type": "number",
        "$value": 0.8
      },
      "full": {
        "$type": "number",
        "$value": 1
      }
    }
  },
  "metadata": {
    "tokenSetOrder": [
      "color",
      "fontFamily",
      "fontSize",
      "lineHeight",
      "letterSpacing",
      "spacing",
      "borderRadius",
      "borderWidth",
      "shadow",
      "transition",
      "zIndex",
      "opacity"
    ]
  }
}
